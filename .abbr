abbr "cp"="cp -i"
abbr "G"="google-chrome"
abbr "gcd"="cd \"\$(git rev-parse --show-toplevel)\""
abbr "gloe"="git ls-files --others --exclude-standard"
abbr "grep"="grep --color=auto"
abbr "l."="ls -d .* --color=auto"
abbr "lc"="tig --reverse remotes/origin/HEAD.."
abbr "ls"="ls --color=auto --group-directories-first"
abbr "mv"="mv -i"
abbr "rm"="rm -i"
abbr "T"="tig status"
abbr "X"="xdg-open"
